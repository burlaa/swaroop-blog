---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Snake"
	description="A minimal Snake game."
>
	<main class="game-shell">
		<section class="game-panel fade-in" aria-label="Snake game">
			<div class="game-topbar">
				<div class="score-display">
					<span class="score-label">Score</span>
					<strong class="score-value" data-score>0</strong>
				</div>
				<div class="topbar-right">
					<div class="speed-switch" role="group" aria-label="Speed" data-speed-group>
						<button type="button" data-speed="slow">Slow</button>
						<button type="button" class="is-active" data-speed="normal">Normal</button>
						<button type="button" data-speed="fast">Fast</button>
					</div>
					<button type="button" class="ghost-button" data-reset>Reset</button>
				</div>
			</div>

			<div class="canvas-wrap">
				<canvas id="snake-canvas" aria-label="Snake game board"></canvas>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.game-shell {
		width: min(100% - 2rem, 680px);
		margin: 0 auto;
		padding: 4rem 0 4rem;
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: calc(100vh - 8rem);
	}

	.game-panel {
		position: relative;
		overflow: hidden;
		width: 100%;
		max-width: 440px;
		border: 1px solid var(--border);
		border-radius: 0.8rem;
		background:
			radial-gradient(circle at 50% 42%, color-mix(in srgb, var(--text-strong) 9%, transparent), transparent 16rem),
			color-mix(in srgb, var(--surface) 82%, transparent);
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--text-strong) 3%, transparent),
			0 18px 60px rgba(0, 0, 0, 0.26);
	}

	.game-panel::before {
		position: absolute;
		inset: -6rem -5rem auto;
		height: 14rem;
		pointer-events: none;
		background:
			radial-gradient(circle, color-mix(in srgb, var(--text-strong) 22%, transparent), transparent 58%),
			radial-gradient(circle at 24% 56%, rgba(143, 171, 255, 0.18), transparent 34%),
			radial-gradient(circle at 76% 54%, rgba(255, 255, 255, 0.12), transparent 34%);
		filter: blur(18px);
		opacity: 0.34;
		content: "";
	}

	.game-topbar,
	.canvas-wrap {
		position: relative;
		z-index: 1;
	}

	.game-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.5rem 0.6rem;
		border-bottom: 1px solid var(--border);
	}

	.score-display {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
	}

	.score-label {
		color: var(--muted-soft);
		font-size: 0.68rem;
		font-weight: 650;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.score-value {
		color: var(--text-strong);
		font-size: 1.1rem;
		font-weight: 650;
		line-height: 1;
	}

	.topbar-right {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.speed-switch {
		display: inline-flex;
		padding: 0.15rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: color-mix(in srgb, var(--bg) 64%, transparent);
	}

	.speed-switch button,
	.ghost-button {
		border: 0;
		color: var(--muted);
		cursor: pointer;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.speed-switch button {
		min-width: 3.2rem;
		padding: 0.35rem 0.5rem;
		border-radius: 999px;
		background: transparent;
		font-size: 0.68rem;
		font-weight: 600;
	}

	.speed-switch button.is-active {
		background: var(--text-strong);
		color: var(--bg);
	}

	.ghost-button {
		padding: 0.38rem 0.6rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: transparent;
		font-size: 0.72rem;
		font-weight: 600;
	}

	.ghost-button:hover {
		border-color: var(--border-strong);
		color: var(--text-strong);
		transform: translateY(-1px);
	}

	.canvas-wrap {
		display: grid;
		place-items: center;
		padding: 0.6rem;
	}

	#snake-canvas {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 0.45rem;
		touch-action: none;
		cursor: pointer;
	}

	@media (max-width: 520px) {
		.game-shell {
			width: min(100% - 0.5rem, 680px);
			padding: 1.5rem 0;
			min-height: auto;
		}

		.game-topbar {
			padding: 0.35rem 0.5rem;
		}

		.speed-switch button {
			min-width: 2.6rem;
			padding: 0.3rem 0.4rem;
			font-size: 0.64rem;
		}

		.ghost-button {
			padding: 0.32rem 0.5rem;
			font-size: 0.68rem;
		}

		.canvas-wrap {
			padding: 0.3rem;
		}
	}
</style>

<script>
	const canvas = document.getElementById('snake-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;
	const scoreEl = document.querySelector<HTMLElement>('[data-score]');
	const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]');
	const speedButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-speed]'));

	const GRID = 20;
	const DPR = window.devicePixelRatio || 1;

	let speed = 'normal';
	let cells = 20;
	let cellSize = 0;
	let gameRunning = false;
	let waitingToStart = true;
	let gameOver = false;
	let score = 0;
	let animFrame = 0;
	let moveTimer = 0;

	type Dir = 'up' | 'down' | 'left' | 'right';
	let dir: Dir = 'right';
	let nextDir: Dir = 'right';
	let snake: { x: number; y: number }[] = [];
	let food: { x: number; y: number } = { x: 10, y: 10 };
	let particles: { x: number; y: number; vx: number; vy: number; life: number; max: number }[] = [];

	function resizeCanvas() {
		const rect = canvas.getBoundingClientRect();
		canvas.width = rect.width * DPR;
		canvas.height = rect.height * DPR;
		ctx.setTransform(1, 0, 0, 1, 0, 0);
		ctx.scale(DPR, DPR);
		cellSize = rect.width / cells;
	}

	function getSpeedMs() {
		if (speed === 'slow') return 140;
		if (speed === 'fast') return 70;
		return 100;
	}

	function resetGame() {
		const mid = Math.floor(cells / 2);
		snake = [
			{ x: mid, y: mid },
			{ x: mid - 1, y: mid },
			{ x: mid - 2, y: mid },
		];
		dir = 'right';
		nextDir = 'right';
		score = 0;
		gameOver = false;
		waitingToStart = true;
		moveTimer = 0;
		particles = [];
		placeFood();
		updateScore();
		draw();
	}

	function placeFood() {
		const occupied = new Set(snake.map((s) => `${s.x},${s.y}`));
		const free: { x: number; y: number }[] = [];
		for (let x = 0; x < cells; x++) {
			for (let y = 0; y < cells; y++) {
				if (!occupied.has(`${x},${y}`)) free.push({ x, y });
			}
		}
		if (free.length === 0) {
			gameOver = true;
			return;
		}
		food = free[Math.floor(Math.random() * free.length)];
	}

	function updateScore() {
		if (scoreEl) scoreEl.textContent = String(score);
	}

	function spawnParticles(x: number, y: number) {
		for (let i = 0; i < 6; i++) {
			const angle = Math.random() * Math.PI * 2;
			const spd = 1 + Math.random() * 2;
			particles.push({
				x: x * cellSize + cellSize / 2,
				y: y * cellSize + cellSize / 2,
				vx: Math.cos(angle) * spd,
				vy: Math.sin(angle) * spd,
				life: 1,
				max: 1,
			});
		}
	}

	function tick() {
		dir = nextDir;

		const head = { ...snake[0] };
		if (dir === 'up') head.y--;
		else if (dir === 'down') head.y++;
		else if (dir === 'left') head.x--;
		else if (dir === 'right') head.x++;

		// Wall wrap
		if (head.x < 0) head.x = cells - 1;
		else if (head.x >= cells) head.x = 0;
		else if (head.y < 0) head.y = cells - 1;
		else if (head.y >= cells) head.y = 0;

		// Self collision
		if (snake.some((s) => s.x === head.x && s.y === head.y)) {
			gameRunning = false;
			gameOver = true;
			draw();
			return;
		}

		snake.unshift(head);

		// Eat food
		if (head.x === food.x && head.y === food.y) {
			score++;
			updateScore();
			spawnParticles(food.x, food.y);
			placeFood();
		} else {
			snake.pop();
		}
	}

	function draw() {
		const w = canvas.getBoundingClientRect().width;
		const h = canvas.getBoundingClientRect().height;
		ctx.clearRect(0, 0, w, h);

		const dark = document.documentElement.dataset.theme !== 'light';
		const gridColor = dark ? 'rgba(255,255,255,0.03)' : 'rgba(0,0,0,0.03)';
		const snakeHead = dark ? '#ffffff' : '#09090b';
		const snakeBody = dark ? 'rgba(255,255,255,0.6)' : 'rgba(9,9,11,0.6)';
		const snakeTail = dark ? 'rgba(255,255,255,0.15)' : 'rgba(9,9,11,0.15)';
		const foodColor = dark ? 'rgba(255,255,255,0.35)' : 'rgba(9,9,11,0.3)';
		const particleColor = dark ? 'rgba(255,255,255,' : 'rgba(9,9,11,';

		// Grid dots
		ctx.fillStyle = gridColor;
		for (let x = 0; x < cells; x++) {
			for (let y = 0; y < cells; y++) {
				ctx.beginPath();
				ctx.arc(x * cellSize + cellSize / 2, y * cellSize + cellSize / 2, 1, 0, Math.PI * 2);
				ctx.fill();
			}
		}

		// Food glow
		const fg = ctx.createRadialGradient(
			food.x * cellSize + cellSize / 2, food.y * cellSize + cellSize / 2, 0,
			food.x * cellSize + cellSize / 2, food.y * cellSize + cellSize / 2, cellSize * 2
		);
		fg.addColorStop(0, dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)');
		fg.addColorStop(1, 'rgba(0,0,0,0)');
		ctx.fillStyle = fg;
		ctx.beginPath();
		ctx.arc(food.x * cellSize + cellSize / 2, food.y * cellSize + cellSize / 2, cellSize * 2, 0, Math.PI * 2);
		ctx.fill();

		// Food
		const pad = cellSize * 0.2;
		ctx.fillStyle = foodColor;
		ctx.beginPath();
		ctx.roundRect(
			food.x * cellSize + pad,
			food.y * cellSize + pad,
			cellSize - pad * 2,
			cellSize - pad * 2,
			cellSize * 0.25
		);
		ctx.fill();

		// Snake
		const len = snake.length;
		for (let i = len - 1; i >= 0; i--) {
			const s = snake[i];
			const t = len > 1 ? i / (len - 1) : 0;
			const p = cellSize * 0.12;

			if (i === 0) {
				// Head glow
				const hg = ctx.createRadialGradient(
					s.x * cellSize + cellSize / 2, s.y * cellSize + cellSize / 2, 0,
					s.x * cellSize + cellSize / 2, s.y * cellSize + cellSize / 2, cellSize * 2
				);
				hg.addColorStop(0, dark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.05)');
				hg.addColorStop(1, 'rgba(0,0,0,0)');
				ctx.fillStyle = hg;
				ctx.beginPath();
				ctx.arc(s.x * cellSize + cellSize / 2, s.y * cellSize + cellSize / 2, cellSize * 2, 0, Math.PI * 2);
				ctx.fill();

				ctx.fillStyle = snakeHead;
			} else {
				const alpha = 0.6 - t * 0.45;
				ctx.fillStyle = dark
					? `rgba(255,255,255,${alpha})`
					: `rgba(9,9,11,${alpha})`;
			}

			ctx.beginPath();
			ctx.roundRect(
				s.x * cellSize + p,
				s.y * cellSize + p,
				cellSize - p * 2,
				cellSize - p * 2,
				cellSize * 0.22
			);
			ctx.fill();
		}

		// Particles
		for (let i = particles.length - 1; i >= 0; i--) {
			const pt = particles[i];
			pt.x += pt.vx;
			pt.y += pt.vy;
			pt.life -= 0.03;
			if (pt.life <= 0) {
				particles.splice(i, 1);
				continue;
			}
			ctx.fillStyle = particleColor + pt.life + ')';
			ctx.beginPath();
			ctx.arc(pt.x, pt.y, 2 * pt.life, 0, Math.PI * 2);
			ctx.fill();
		}

		// Overlay
		if (waitingToStart || gameOver) {
			ctx.fillStyle = dark ? 'rgba(0,0,0,0.55)' : 'rgba(255,255,255,0.55)';
			ctx.fillRect(0, 0, w, h);

			ctx.fillStyle = snakeHead;
			ctx.textAlign = 'center';
			ctx.textBaseline = 'middle';

			if (gameOver) {
				ctx.font = '600 22px Inter, system-ui, sans-serif';
				ctx.fillText('Game over', w / 2, h / 2 - 12);
				ctx.font = '500 12px Inter, system-ui, sans-serif';
				ctx.fillStyle = dark ? 'rgba(255,255,255,0.5)' : 'rgba(0,0,0,0.45)';
				ctx.fillText(`Score: ${score} · Click to retry`, w / 2, h / 2 + 14);
			} else {
				ctx.font = '600 20px Inter, system-ui, sans-serif';
				ctx.fillText('Snake', w / 2, h / 2 - 10);
				ctx.font = '500 11px Inter, system-ui, sans-serif';
				ctx.fillStyle = dark ? 'rgba(255,255,255,0.45)' : 'rgba(0,0,0,0.4)';
				const hint = isTouchDevice ? 'Tap to start' : 'Arrow keys to play';
				ctx.fillText(hint, w / 2, h / 2 + 12);
			}
		}
	}

	// Game loop with timing
	let lastMove = 0;

	function loop(ts: number) {
		if (!gameRunning) {
			draw();
			return;
		}

		if (ts - lastMove >= getSpeedMs()) {
			lastMove = ts;
			tick();
		}

		draw();
		animFrame = requestAnimationFrame(loop);
	}

	function startGame() {
		if (gameRunning) return;
		gameRunning = true;
		waitingToStart = false;
		gameOver = false;
		lastMove = 0;
		if (animFrame) cancelAnimationFrame(animFrame);
		animFrame = requestAnimationFrame(loop);
	}

	// Input
	const keys: Record<string, boolean> = {};
	const opposites: Record<Dir, Dir> = { up: 'down', down: 'up', left: 'right', right: 'left' };

	function setDirection(d: Dir) {
		if (opposites[d] !== dir) nextDir = d;
	}

	document.addEventListener('keydown', (e) => {
		keys[e.key] = true;
		if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
			e.preventDefault();
			if (!gameRunning && (waitingToStart || gameOver)) {
				startGame();
			}
		}
		if (e.key === 'ArrowUp' || e.key === 'w' || e.key === 'W') setDirection('up');
		else if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') setDirection('down');
		else if (e.key === 'ArrowLeft' || e.key === 'a' || e.key === 'A') setDirection('left');
		else if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') setDirection('right');
	});

	document.addEventListener('keyup', (e) => { keys[e.key] = false; });

	// Touch swipe
	let touchStart: { x: number; y: number } | null = null;

	canvas.addEventListener('touchstart', (e) => {
		e.preventDefault();
		if (waitingToStart || gameOver) {
			startGame();
			return;
		}
		const t = e.touches[0];
		touchStart = { x: t.clientX, y: t.clientY };
	}, { passive: false });

	canvas.addEventListener('touchmove', (e) => {
		e.preventDefault();
		if (!touchStart) return;
		const t = e.touches[0];
		const dx = t.clientX - touchStart.x;
		const dy = t.clientY - touchStart.y;
		const threshold = 20;

		if (Math.abs(dx) > threshold || Math.abs(dy) > threshold) {
			if (Math.abs(dx) > Math.abs(dy)) {
				setDirection(dx > 0 ? 'right' : 'left');
			} else {
				setDirection(dy > 0 ? 'down' : 'up');
			}
			touchStart = { x: t.clientX, y: t.clientY };
		}
	}, { passive: false });

	// Speed
	speedButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			speed = btn.dataset.speed || 'normal';
			speedButtons.forEach((b) => b.classList.toggle('is-active', b === btn));
		});
	});

	resetButton?.addEventListener('click', resetGame);

	canvas.addEventListener('click', () => {
		if (waitingToStart || gameOver) startGame();
	});

	// Init
	resizeCanvas();
	resetGame();
	window.addEventListener('resize', () => { resizeCanvas(); draw(); });
</script>
