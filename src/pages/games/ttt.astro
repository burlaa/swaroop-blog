---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Tic Tac Toe"
	description="A minimal Tic Tac Toe game with computer and two-player modes."
>
	<main class="game-shell">
		<section class="game-hero fade-in">
			<p class="eyebrow">Small game</p>
			<h1>Tic Tac Toe</h1>
			<p>A quiet little board for quick rounds, clean wins, and beautiful draws.</p>
		</section>

		<section class="ttt-panel fade-in" aria-label="Tic Tac Toe game">
			<div class="ttt-topbar">
				<div class="mode-switch" role="group" aria-label="Game mode">
					<button type="button" class="is-active" data-mode="computer">Computer</button>
					<button type="button" data-mode="players">2 Players</button>
				</div>
				<button type="button" class="ghost-button" data-reset>Reset</button>
			</div>

			<div class="score-grid" aria-label="Score">
				<div>
					<span data-score-label-x>You</span>
					<strong data-score-x>0</strong>
				</div>
				<div>
					<span>Draws</span>
					<strong data-score-draws>0</strong>
				</div>
				<div>
					<span data-score-label-o>Computer</span>
					<strong data-score-o>0</strong>
				</div>
			</div>

			<p class="game-status" data-status aria-live="polite">Your turn.</p>

			<div class="board-wrap">
				<div class="ttt-board" role="grid" aria-label="Tic Tac Toe board">
					{
						Array.from({ length: 9 }).map((_, index) => (
							<button
								type="button"
								class="ttt-cell"
								data-cell={index}
								aria-label={`Cell ${index + 1}`}
							/>
						))
					}
				</div>
			</div>

			<div class="round-actions">
				<button type="button" class="primary-button" data-next>Next round</button>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.game-shell {
		width: min(100% - 2rem, 680px);
		margin: 0 auto;
		padding: 2.1rem 0 3rem;
	}

	.game-hero {
		max-width: 520px;
		margin-bottom: 0.95rem;
	}

	.game-hero h1 {
		margin: 0;
		color: var(--text-strong);
		font-size: clamp(2rem, 5.6vw, 3.05rem);
		font-weight: 650;
		line-height: 1;
	}

	.game-hero p:not(.eyebrow) {
		max-width: 460px;
		margin: 0.5rem 0 0;
		color: var(--muted);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.ttt-panel {
		position: relative;
		overflow: hidden;
		max-width: 520px;
		border: 1px solid var(--border);
		border-radius: 0.8rem;
		background:
			radial-gradient(circle at 50% 42%, color-mix(in srgb, var(--text-strong) 9%, transparent), transparent 16rem),
			color-mix(in srgb, var(--surface) 82%, transparent);
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--text-strong) 3%, transparent),
			0 18px 60px rgba(0, 0, 0, 0.26);
	}

	.ttt-panel::before {
		position: absolute;
		inset: -6rem -5rem auto;
		height: 14rem;
		pointer-events: none;
		background:
			radial-gradient(circle, color-mix(in srgb, var(--text-strong) 22%, transparent), transparent 58%),
			radial-gradient(circle at 24% 56%, rgba(143, 171, 255, 0.18), transparent 34%),
			radial-gradient(circle at 76% 54%, rgba(255, 255, 255, 0.12), transparent 34%);
		filter: blur(18px);
		opacity: 0.34;
		content: "";
	}

	.ttt-topbar,
	.score-grid,
	.game-status,
	.board-wrap,
	.round-actions {
		position: relative;
		z-index: 1;
	}

	.ttt-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.7rem;
		border-bottom: 1px solid var(--border);
	}

	.mode-switch {
		display: inline-flex;
		padding: 0.18rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: color-mix(in srgb, var(--bg) 64%, transparent);
	}

	.mode-switch button,
	.ghost-button,
	.primary-button {
		border: 0;
		color: var(--muted);
		cursor: pointer;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.mode-switch button {
		min-width: 5.45rem;
		padding: 0.42rem 0.7rem;
		border-radius: 999px;
		background: transparent;
		font-size: 0.78rem;
		font-weight: 620;
	}

	.mode-switch button.is-active {
		background: var(--text-strong);
		color: var(--bg);
	}

	.ghost-button,
	.primary-button {
		border: 1px solid var(--border);
		border-radius: 999px;
		background: transparent;
		font-size: 0.78rem;
		font-weight: 620;
	}

	.ghost-button {
		padding: 0.48rem 0.75rem;
	}

	.primary-button {
		padding: 0.62rem 0.9rem;
		background: var(--text-strong);
		color: var(--bg);
	}

	.ghost-button:hover,
	.primary-button:hover {
		transform: translateY(-1px);
	}

	.ghost-button:hover {
		border-color: var(--border-strong);
		color: var(--text-strong);
	}

	.score-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--border);
	}

	.score-grid div {
		padding: 0.62rem 0.5rem;
		background: color-mix(in srgb, var(--surface) 88%, transparent);
	}

	.score-grid span,
	.score-grid strong {
		display: block;
		text-align: center;
	}

	.score-grid span {
		color: var(--muted-soft);
		font-size: 0.66rem;
		font-weight: 650;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.score-grid strong {
		margin-top: 0.2rem;
		color: var(--text-strong);
		font-size: 1.22rem;
		font-weight: 650;
		line-height: 1;
	}

	.game-status {
		margin: 0;
		min-height: 2.35rem;
		padding: 0.72rem 1rem 0;
		color: var(--text-strong);
		font-size: 0.86rem;
		font-weight: 580;
		text-align: center;
	}

	.board-wrap {
		display: grid;
		place-items: center;
		padding: 0.65rem 1rem 0.6rem;
	}

	.ttt-board {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		grid-template-rows: repeat(3, minmax(0, 1fr));
		width: min(100%, 15.65rem);
		aspect-ratio: 1;
		gap: 0.42rem;
	}

	.ttt-cell {
		display: grid;
		place-items: center;
		width: 100%;
		min-width: 0;
		aspect-ratio: 1;
		border: 1px solid var(--border);
		border-radius: 0.45rem;
		background: color-mix(in srgb, var(--bg) 72%, transparent);
		color: var(--text-strong);
		cursor: pointer;
		font-size: clamp(1.7rem, 9vw, 3rem);
		font-weight: 520;
		line-height: 1;
		text-align: center;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--text-strong) 6%, transparent);
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			box-shadow 180ms ease;
	}

	.ttt-cell:hover:not(:disabled) {
		border-color: var(--border-strong);
		box-shadow:
			inset 0 1px 0 color-mix(in srgb, var(--text-strong) 10%, transparent),
			0 0 24px color-mix(in srgb, var(--text-strong) 7%, transparent);
	}

	.ttt-cell:disabled {
		cursor: default;
	}

	.ttt-cell.is-x {
		color: var(--text-strong);
	}

	.ttt-cell.is-o {
		color: var(--muted);
	}

	.ttt-cell.is-win {
		border-color: color-mix(in srgb, var(--text-strong) 42%, transparent);
		background: color-mix(in srgb, var(--text-strong) 9%, var(--surface));
		box-shadow: 0 0 28px color-mix(in srgb, var(--text-strong) 12%, transparent);
	}

	.round-actions {
		display: flex;
		justify-content: center;
		padding: 0 1rem 0.75rem;
	}

	@media (max-width: 720px) {
		.game-shell {
			width: min(100% - 1rem, 680px);
			padding-top: 1.35rem;
		}

		.game-hero h1 {
			font-size: clamp(2rem, 12vw, 3rem);
		}

		.ttt-topbar {
			align-items: stretch;
			flex-direction: column;
		}

		.mode-switch,
		.ghost-button {
			width: 100%;
		}

		.mode-switch button {
			flex: 1;
			min-width: 0;
		}

		.score-grid div {
			padding: 0.58rem 0.35rem;
		}

		.score-grid strong {
			font-size: 1.1rem;
		}

		.ttt-board {
			width: min(100%, 14.75rem);
			gap: 0.36rem;
		}

		.ttt-cell {
			border-radius: 0.4rem;
		}
	}
</style>

<script>
	const cells = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-cell]'));
	const statusEl = document.querySelector<HTMLElement>('[data-status]');
	const nextButton = document.querySelector<HTMLButtonElement>('[data-next]');
	const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]');
	const modeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-mode]'));
	const scoreX = document.querySelector<HTMLElement>('[data-score-x]');
	const scoreO = document.querySelector<HTMLElement>('[data-score-o]');
	const scoreDraws = document.querySelector<HTMLElement>('[data-score-draws]');
	const scoreLabelX = document.querySelector<HTMLElement>('[data-score-label-x]');
	const scoreLabelO = document.querySelector<HTMLElement>('[data-score-label-o]');

	const wins = [
		[0, 1, 2],
		[3, 4, 5],
		[6, 7, 8],
		[0, 3, 6],
		[1, 4, 7],
		[2, 5, 8],
		[0, 4, 8],
		[2, 4, 6],
	];

	let board = Array<string>(9).fill('');
	let mode = 'computer';
	let turn = 'X';
	let startingMark = 'X';
	let gameOver = false;
	let scores = { x: 0, o: 0, draws: 0 };

	const humanMark = 'X';
	const computerMark = 'O';

	function winnerFor(nextBoard: string[]) {
		for (const line of wins) {
			const [a, b, c] = line;
			if (nextBoard[a] && nextBoard[a] === nextBoard[b] && nextBoard[a] === nextBoard[c]) {
				return { mark: nextBoard[a], line };
			}
		}

		if (nextBoard.every(Boolean)) {
			return { mark: 'draw', line: [] };
		}

		return null;
	}

	function updateScores() {
		if (!scoreX || !scoreO || !scoreDraws || !scoreLabelX || !scoreLabelO) return;
		scoreX.textContent = String(scores.x);
		scoreO.textContent = String(scores.o);
		scoreDraws.textContent = String(scores.draws);
		scoreLabelX.textContent = mode === 'computer' ? 'You' : 'Player X';
		scoreLabelO.textContent = mode === 'computer' ? 'Computer' : 'Player O';
	}

	function statusForTurn() {
		if (!statusEl) return;
		if (mode === 'computer') {
			statusEl.textContent = turn === humanMark ? 'Your turn.' : 'Computer is thinking.';
			return;
		}

		statusEl.textContent = `Player ${turn}'s turn.`;
	}

	function render() {
		cells.forEach((cell, index) => {
			const value = board[index];
			cell.textContent = value;
			cell.disabled = gameOver || Boolean(value) || (mode === 'computer' && turn === computerMark);
			cell.classList.toggle('is-x', value === 'X');
			cell.classList.toggle('is-o', value === 'O');
			cell.classList.remove('is-win');
			cell.setAttribute('aria-label', value ? `Cell ${index + 1}, ${value}` : `Cell ${index + 1}, empty`);
		});
		updateScores();
		statusForTurn();
	}

	function finish(result: { mark: string; line: number[] }) {
		gameOver = true;

		result.line.forEach((index) => cells[index]?.classList.add('is-win'));

		if (result.mark === 'draw') {
			scores.draws += 1;
			if (statusEl) statusEl.textContent = 'Draw. A clean stalemate.';
		} else if (result.mark === 'X') {
			scores.x += 1;
			if (statusEl) statusEl.textContent = mode === 'computer' ? 'You win.' : 'Player X wins.';
		} else {
			scores.o += 1;
			if (statusEl) statusEl.textContent = mode === 'computer' ? 'Computer wins.' : 'Player O wins.';
		}

		updateScores();
		cells.forEach((cell) => (cell.disabled = true));
	}

	function play(index: number) {
		if (gameOver || board[index]) return;
		if (mode === 'computer' && turn === computerMark) return;

		board[index] = turn;
		const result = winnerFor(board);
		if (result) {
			render();
			finish(result);
			return;
		}

		turn = turn === 'X' ? 'O' : 'X';
		render();

		if (mode === 'computer' && turn === computerMark) {
			window.setTimeout(computerMove, 360);
		}
	}

	function findWinningMove(mark: string) {
		for (let index = 0; index < board.length; index += 1) {
			if (board[index]) continue;
			const candidate = [...board];
			candidate[index] = mark;
			if (winnerFor(candidate)?.mark === mark) return index;
		}
		return -1;
	}

	function computerMove() {
		if (gameOver || mode !== 'computer') return;

		let move = findWinningMove(computerMark);
		if (move < 0) move = findWinningMove(humanMark);
		if (move < 0 && !board[4]) move = 4;
		const fallbackOrder = [0, 2, 6, 8, 1, 3, 5, 7];
		const index = move >= 0 ? move : fallbackOrder.find((slot) => !board[slot]);

		if (index === undefined) return;

		board[index] = computerMark;
		const result = winnerFor(board);
		if (result) {
			render();
			finish(result);
			return;
		}

		turn = humanMark;
		render();
	}

	function nextRound() {
		startingMark = startingMark === 'X' ? 'O' : 'X';
		board = Array<string>(9).fill('');
		turn = startingMark;
		gameOver = false;
		render();

		if (mode === 'computer' && turn === computerMark) {
			window.setTimeout(computerMove, 420);
		}
	}

	function resetGame() {
		scores = { x: 0, o: 0, draws: 0 };
		startingMark = 'X';
		board = Array<string>(9).fill('');
		turn = startingMark;
		gameOver = false;
		render();
	}

	cells.forEach((cell, index) => {
		cell.addEventListener('click', () => play(index));
	});

	nextButton?.addEventListener('click', nextRound);
	resetButton?.addEventListener('click', resetGame);

	modeButtons.forEach((button) => {
		button.addEventListener('click', () => {
			mode = button.dataset.mode || 'computer';
			modeButtons.forEach((item) => item.classList.toggle('is-active', item === button));
			resetGame();
		});
	});

	render();
</script>
