---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="2048"
	description="A minimal 2048 puzzle game."
>
	<main class="game-shell">
		<section class="game-panel fade-in" aria-label="2048 game">
			<div class="game-topbar">
				<div class="score-display">
					<span class="score-label">Score</span>
					<strong class="score-value" data-score>0</strong>
				</div>
				<div class="topbar-right">
					<button type="button" class="ghost-button" data-reset>New game</button>
				</div>
			</div>

			<div class="canvas-wrap">
				<canvas id="game-canvas" aria-label="2048 game board"></canvas>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.game-shell {
		width: min(100% - 2rem, 680px);
		margin: 0 auto;
		padding: 4rem 0 3rem;
		display: flex;
		justify-content: center;
	}

	.game-panel {
		position: relative;
		overflow: hidden;
		width: 100%;
		max-width: 400px;
		border: 1px solid var(--border);
		border-radius: 0.8rem;
		background:
			radial-gradient(circle at 50% 42%, color-mix(in srgb, var(--text-strong) 9%, transparent), transparent 16rem),
			color-mix(in srgb, var(--surface) 82%, transparent);
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--text-strong) 3%, transparent),
			0 18px 60px rgba(0, 0, 0, 0.26);
	}

	.game-panel::before {
		position: absolute;
		inset: -6rem -5rem auto;
		height: 14rem;
		pointer-events: none;
		background:
			radial-gradient(circle, color-mix(in srgb, var(--text-strong) 22%, transparent), transparent 58%),
			radial-gradient(circle at 24% 56%, rgba(143, 171, 255, 0.18), transparent 34%),
			radial-gradient(circle at 76% 54%, rgba(255, 255, 255, 0.12), transparent 34%);
		filter: blur(18px);
		opacity: 0.34;
		content: "";
	}

	.game-topbar,
	.canvas-wrap,
	.mobile-arrows {
		position: relative;
		z-index: 1;
	}

	.game-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.5rem 0.6rem;
		border-bottom: 1px solid var(--border);
	}

	.score-display {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
	}

	.score-label {
		color: var(--muted-soft);
		font-size: 0.68rem;
		font-weight: 650;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.score-value {
		color: var(--text-strong);
		font-size: 1.1rem;
		font-weight: 650;
		line-height: 1;
	}

	.topbar-right {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.ghost-button {
		padding: 0.38rem 0.6rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		font-size: 0.72rem;
		font-weight: 600;
		transition:
			border-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.ghost-button:hover {
		border-color: var(--border-strong);
		color: var(--text-strong);
		transform: translateY(-1px);
	}

	.canvas-wrap {
		display: grid;
		place-items: center;
		padding: 0.6rem;
	}

	#game-canvas {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 0.45rem;
		touch-action: none;
		cursor: pointer;
	}

	@media (max-width: 520px) {
		.game-shell {
			width: min(100% - 0.5rem, 680px);
			padding-top: 1rem;
		}

		.game-topbar {
			padding: 0.35rem 0.5rem;
		}

		.ghost-button {
			padding: 0.32rem 0.5rem;
			font-size: 0.68rem;
		}

		.canvas-wrap {
			padding: 0.3rem;
		}
	}
</style>

<script>
	const canvas = document.getElementById('game-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;
	const scoreEl = document.querySelector<HTMLElement>('[data-score]');
	const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]');

	const SIZE = 4;
	const DPR = window.devicePixelRatio || 1;
	const GAP = 8;
	const RADIUS = 6;
	const ANIM_MS = 120;

	let grid: (number | null)[][] = [];
	let score = 0;
	let gameOver = false;
	let won = false;
	let keepPlaying = false;
	let inputLocked = false;

	// Tile tracking for animations
	interface Tile {
		id: number;
		value: number;
		row: number;
		col: number;
		previousRow: number;
		previousCol: number;
		merged: boolean;
		mergedFrom: [number, number]; // [id1, id2] that merged into this
		spawned: boolean;
	}
	let tiles: Tile[] = [];
	let nextId = 0;

	// Animation state
	let animStart = 0;
	let animating = false;
	interface AnimTile {
		id: number;
		value: number;
		fromRow: number;
		fromCol: number;
		toRow: number;
		toCol: number;
		merged: boolean;
		spawned: boolean;
	}
	let activeAnims: AnimTile[] = [];

	function resizeCanvas() {
		const rect = canvas.getBoundingClientRect();
		canvas.width = rect.width * DPR;
		canvas.height = rect.height * DPR;
		ctx.setTransform(1, 0, 0, 1, 0, 0);
		ctx.scale(DPR, DPR);
	}

	function cellSize() {
		const rect = canvas.getBoundingClientRect();
		return (rect.width - GAP * (SIZE + 1)) / SIZE;
	}

	function cellPos(row: number, col: number) {
		const cs = cellSize();
		return {
			x: GAP + col * (cs + GAP),
			y: GAP + row * (cs + GAP),
			w: cs,
			h: cs,
		};
	}

	function initGrid() {
		grid = Array.from({ length: SIZE }, () => Array(SIZE).fill(null));
		tiles = [];
		nextId = 0;
	}

	function spawnTile(animate = false) {
		const empty: [number, number][] = [];
		for (let r = 0; r < SIZE; r++) {
			for (let c = 0; c < SIZE; c++) {
				if (grid[r][c] === null) empty.push([r, c]);
			}
		}
		if (empty.length === 0) return;
		const [r, c] = empty[Math.floor(Math.random() * empty.length)];
		const val = Math.random() < 0.9 ? 2 : 4;
		grid[r][c] = val;

		const tile: Tile = {
			id: nextId++,
			value: val,
			row: r,
			col: c,
			previousRow: r,
			previousCol: c,
			merged: false,
			mergedFrom: [-1, -1],
			spawned: animate,
		};
		tiles.push(tile);

		if (animate) {
			activeAnims.push({
				id: tile.id,
			 value: val,
				fromRow: r,
				fromCol: c,
				toRow: r,
				toCol: c,
				merged: false,
				spawned: true,
			});
		}
	}

	function resetGame() {
		initGrid();
		score = 0;
		gameOver = false;
		won = false;
		keepPlaying = false;
		inputLocked = false;
		activeAnims = [];
		animating = false;
		updateScore();
		spawnTile();
		spawnTile();
		draw(1);
	}

	function updateScore() {
		if (scoreEl) scoreEl.textContent = String(score);
	}

	// Slide a single line (array of values) to the left
	function slideLine(line: (number | null)[]): { result: (number | null)[]; scoreAdd: number; mergedIndices: number[] } {
		const filtered = line.filter((v): v is number => v !== null);
		const result: (number | null)[] = [];
		let scoreAdd = 0;
		const mergedIndices: number[] = [];
		let i = 0;
		while (i < filtered.length) {
			if (i + 1 < filtered.length && filtered[i] === filtered[i + 1]) {
				const merged = filtered[i] * 2;
				result.push(merged);
				scoreAdd += merged;
				mergedIndices.push(result.length - 1);
				i += 2;
			} else {
				result.push(filtered[i]);
				i++;
			}
		}
		while (result.length < SIZE) result.push(null);
		return { result, scoreAdd, mergedIndices };
	}

	function move(dir: 'up' | 'down' | 'left' | 'right') {
		if (gameOver || inputLocked) return;

		// Save previous positions
		for (const tile of tiles) {
			tile.previousRow = tile.row;
			tile.previousCol = tile.col;
			tile.merged = false;
			tile.mergedFrom = [-1, -1];
			tile.spawned = false;
		}

		const oldGrid = grid.map((r) => [...r]);
		activeAnims = [];
		let totalScore = 0;

		// Process each line perpendicular to the move direction
		for (let i = 0; i < SIZE; i++) {
			// Extract the line of values
			let line: (number | null)[];
			let getRC: (j: number) => [number, number];

			if (dir === 'left') {
				line = [...grid[i]];
				getRC = (j) => [i, j];
			} else if (dir === 'right') {
				line = [...grid[i]].reverse();
				getRC = (j) => [i, SIZE - 1 - j];
			} else if (dir === 'up') {
				line = grid.map((r) => r[i]);
				getRC = (j) => [j, i];
			} else {
				line = grid.map((r) => r[i]).reverse();
				getRC = (j) => [SIZE - 1 - j, i];
			}

			const { result, scoreAdd, mergedIndices } = slideLine(line);
			totalScore += scoreAdd;

			// Figure out where each tile in the result came from
			// We need to track which original tiles moved where
			const lineTiles: Tile[] = [];
			for (let j = 0; j < SIZE; j++) {
				const [r, c] = getRC(j);
				const tile = tiles.find((t) => t.row === r && t.col === c && !t.merged);
				if (tile) lineTiles.push(tile);
			}

			// Place results and create animations
			for (let j = 0; j < SIZE; j++) {
				const [r, c] = getRC(j);
				const val = result[j];
				grid[r][c] = val;

				if (val === null) continue;

				const isMerged = mergedIndices.includes(j);

				if (isMerged) {
					// Two tiles merged - find the two source tiles
					// The merged tile takes the position of the second one
					const src1 = lineTiles.shift();
					const src2 = lineTiles.shift();

					if (src1 && src2) {
						// Animate both source tiles moving to the merge position
						activeAnims.push({
							id: src1.id,
							value: src1.value,
							fromRow: src1.previousRow,
							fromCol: src1.previousCol,
							toRow: r,
							toCol: c,
							merged: false,
							spawned: false,
						});
						activeAnims.push({
							id: src2.id,
							value: src2.value,
							fromRow: src2.previousRow,
							fromCol: src2.previousCol,
							toRow: r,
							toCol: c,
							merged: false,
							spawned: false,
						});

						// Remove old tiles, add merged tile
						tiles = tiles.filter((t) => t.id !== src1.id && t.id !== src2.id);
						const mergedTile: Tile = {
							id: nextId++,
							value: val,
							row: r,
							col: c,
							previousRow: r,
							previousCol: c,
							merged: true,
							mergedFrom: [src1.id, src2.id],
							spawned: false,
						};
						tiles.push(mergedTile);

						// Merge pop animation (slightly delayed)
						activeAnims.push({
							id: mergedTile.id,
							value: val,
							fromRow: r,
							fromCol: c,
							toRow: r,
							toCol: c,
							merged: true,
							spawned: false,
						});
					}
				} else {
					// Simple move - one tile slides
					const tile = lineTiles.shift();
					if (tile) {
						tile.row = r;
						tile.col = c;
						activeAnims.push({
							id: tile.id,
							value: tile.value,
							fromRow: tile.previousRow,
							fromCol: tile.previousCol,
							toRow: r,
							toCol: c,
							merged: false,
							spawned: false,
						});
					}
				}
			}
		}

		// Check if anything changed
		const changed = grid.some((r, ri) => r.some((v, ci) => v !== oldGrid[ri][ci]));
		if (!changed) return;

		score += totalScore;
		updateScore();

		// Check win
		if (!won && !keepPlaying) {
			for (let r = 0; r < SIZE; r++) {
				for (let c = 0; c < SIZE; c++) {
					if (grid[r][c] === 2048) won = true;
				}
			}
		}

		// Lock input and start animation
		inputLocked = true;
		animStart = performance.now();
		animating = true;

		// Spawn new tile after a short delay
		setTimeout(() => {
			spawnTile(true);
			if (!canMove()) gameOver = true;
		}, ANIM_MS * 0.6);

		requestAnimationFrame(animLoop);
	}

	function canMove(): boolean {
		for (let r = 0; r < SIZE; r++) {
			for (let c = 0; c < SIZE; c++) {
				if (grid[r][c] === null) return true;
				if (c + 1 < SIZE && grid[r][c] === grid[r][c + 1]) return true;
				if (r + 1 < SIZE && grid[r][c] === grid[r + 1][c]) return true;
			}
		}
		return false;
	}

	// Easing
	function easeOutCubic(t: number) {
		return 1 - Math.pow(1 - t, 3);
	}

	function easeOutBack(t: number) {
		const c = 1.70158;
		return 1 + (t - 1) * (t - 1) * ((c + 1) * (t - 1) + c);
	}

	// Animation loop
	function animLoop(ts: number) {
		if (!animating) return;

		const elapsed = ts - animStart;
		const t = Math.min(1, elapsed / ANIM_MS);
		const eased = easeOutCubic(t);

		draw(eased);

		if (t < 1) {
			requestAnimationFrame(animLoop);
		} else {
			animating = false;
			inputLocked = false;
			activeAnims = [];
			draw(1);
		}
	}

	// Drawing
	function draw(animT: number) {
		const rect = canvas.getBoundingClientRect();
		const w = rect.width;
		const h = rect.height;
		ctx.clearRect(0, 0, w, h);

		const dark = document.documentElement.dataset.theme !== 'light';
		const cs = cellSize();
		const bgColor = dark ? 'rgba(255,255,255,0.03)' : 'rgba(0,0,0,0.03)';

		// Grid background cells
		for (let r = 0; r < SIZE; r++) {
			for (let c = 0; c < SIZE; c++) {
				const { x, y } = cellPos(r, c);
				ctx.fillStyle = bgColor;
				ctx.beginPath();
				ctx.roundRect(x, y, cs, cs, RADIUS);
				ctx.fill();
			}
		}

		// Build a map of animated tile positions
		const animMap = new Map<number, { x: number; y: number; scale: number; alpha: number }>();
		const mergedPositions = new Set<string>();

		for (const a of activeAnims) {
			const from = cellPos(a.fromRow, a.fromCol);
			const to = cellPos(a.toRow, a.toCol);

			const x = from.x + (to.x - from.x) * animT;
			const y = from.y + (to.y - from.y) * animT;

			if (a.merged && a.fromRow === a.toRow && a.fromCol === a.toCol) {
				// Merge pop - scale up briefly
				const popT = animT < 0.5 ? animT * 2 : 2 - animT * 2;
				const scale = 1 + easeOutBack(popT) * 0.15;
				animMap.set(a.id, { x, y, scale, alpha: 1 });
				mergedPositions.add(`${a.toRow},${a.toCol}`);
			} else if (a.spawned) {
				// Spawn pop
				const scale = easeOutBack(animT);
				animMap.set(a.id, { x, y, scale, alpha: animT });
			} else {
				animMap.set(a.id, { x, y, scale: 1, alpha: 1 });
			}
		}

		// Draw tiles
		for (const tile of tiles) {
			const anim = animMap.get(tile.id);
			const { x: baseX, y: baseY } = cellPos(tile.row, tile.col);
			const x = anim ? anim.x : baseX;
			const y = anim ? anim.y : baseY;
			const scale = anim ? anim.scale : 1;
			const alpha = anim ? anim.alpha : 1;

			const colors = tileColors(tile.value, dark);
			const cx = x + cs / 2;
			const cy = y + cs / 2;
			const drawW = cs * scale;
			const drawH = cs * scale;
			const drawX = cx - drawW / 2;
			const drawY = cy - drawH / 2;

			// Glow for high values
			if (tile.value >= 128 && !anim?.spawned) {
				const glow = ctx.createRadialGradient(cx, cy, 0, cx, cy, cs * 0.8);
				glow.addColorStop(0, dark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.03)');
				glow.addColorStop(1, 'rgba(0,0,0,0)');
				ctx.fillStyle = glow;
				ctx.beginPath();
				ctx.arc(cx, cy, cs * 0.8, 0, Math.PI * 2);
				ctx.fill();
			}

			ctx.globalAlpha = alpha;
			ctx.fillStyle = colors.bg;
			ctx.beginPath();
			ctx.roundRect(drawX, drawY, drawW, drawH, RADIUS * scale);
			ctx.fill();

			// Number
			ctx.fillStyle = colors.fg;
			const fontSize = tile.value >= 1024 ? drawW * 0.28 : tile.value >= 128 ? drawW * 0.32 : drawW * 0.38;
			ctx.font = `650 ${fontSize}px Inter, system-ui, sans-serif`;
			ctx.textAlign = 'center';
			ctx.textBaseline = 'middle';
			ctx.fillText(String(tile.value), cx, cy + 1);
			ctx.globalAlpha = 1;
		}

		// Overlay
		if (gameOver || (won && !keepPlaying)) {
			ctx.fillStyle = dark ? 'rgba(0,0,0,0.55)' : 'rgba(255,255,255,0.55)';
			ctx.fillRect(0, 0, w, h);

			ctx.fillStyle = dark ? '#ffffff' : '#09090b';
			ctx.textAlign = 'center';
			ctx.textBaseline = 'middle';

			if (won && !keepPlaying) {
				ctx.font = '650 26px Inter, system-ui, sans-serif';
				ctx.fillText('You win!', w / 2, h / 2 - 14);
				ctx.font = '500 12px Inter, system-ui, sans-serif';
				ctx.fillStyle = dark ? 'rgba(255,255,255,0.5)' : 'rgba(0,0,0,0.45)';
				ctx.fillText('Click to keep playing', w / 2, h / 2 + 12);
			} else {
				ctx.font = '650 26px Inter, system-ui, sans-serif';
				ctx.fillText('Game over', w / 2, h / 2 - 14);
				ctx.font = '500 12px Inter, system-ui, sans-serif';
				ctx.fillStyle = dark ? 'rgba(255,255,255,0.5)' : 'rgba(0,0,0,0.45)';
				ctx.fillText('Click to try again', w / 2, h / 2 + 12);
			}
		}
	}

	function tileColors(value: number, dark: boolean) {
		const colors: Record<number, { bg: string; fg: string }> = dark
			? {
				2:    { bg: 'rgba(255,255,255,0.06)', fg: 'rgba(255,255,255,0.9)' },
				4:    { bg: 'rgba(255,255,255,0.09)', fg: 'rgba(255,255,255,0.9)' },
				8:    { bg: 'rgba(255,255,255,0.14)', fg: 'rgba(255,255,255,0.95)' },
				16:   { bg: 'rgba(255,255,255,0.2)', fg: '#ffffff' },
				32:   { bg: 'rgba(255,255,255,0.27)', fg: '#ffffff' },
				64:   { bg: 'rgba(255,255,255,0.35)', fg: '#ffffff' },
				128:  { bg: 'rgba(255,255,255,0.42)', fg: '#000000' },
				256:  { bg: 'rgba(255,255,255,0.5)', fg: '#000000' },
				512:  { bg: 'rgba(255,255,255,0.6)', fg: '#000000' },
				1024: { bg: 'rgba(255,255,255,0.72)', fg: '#000000' },
				2048: { bg: '#ffffff', fg: '#000000' },
			}
			: {
				2:    { bg: 'rgba(0,0,0,0.04)', fg: '#09090b' },
				4:    { bg: 'rgba(0,0,0,0.07)', fg: '#09090b' },
				8:    { bg: 'rgba(0,0,0,0.12)', fg: '#09090b' },
				16:   { bg: 'rgba(0,0,0,0.18)', fg: '#09090b' },
				32:   { bg: 'rgba(0,0,0,0.25)', fg: '#fafafa' },
				64:   { bg: 'rgba(0,0,0,0.35)', fg: '#fafafa' },
				128:  { bg: 'rgba(0,0,0,0.45)', fg: '#fafafa' },
				256:  { bg: 'rgba(0,0,0,0.55)', fg: '#fafafa' },
				512:  { bg: 'rgba(0,0,0,0.65)', fg: '#fafafa' },
				1024: { bg: 'rgba(0,0,0,0.75)', fg: '#fafafa' },
				2048: { bg: '#09090b', fg: '#fafafa' },
			};
		return colors[value] || colors[2048];
	}

	// Input
	document.addEventListener('keydown', (e) => {
		const map: Record<string, 'up' | 'down' | 'left' | 'right'> = {
			ArrowUp: 'up', ArrowDown: 'down', ArrowLeft: 'left', ArrowRight: 'right',
			w: 'up', s: 'down', a: 'left', d: 'right',
			W: 'up', S: 'down', A: 'left', D: 'right',
		};
		const dir = map[e.key];
		if (dir) {
			e.preventDefault();
			if (gameOver) { resetGame(); return; }
			if (won && !keepPlaying) { keepPlaying = true; draw(1); }
			move(dir);
		}
	});

	// Touch swipe
	let touchStart: { x: number; y: number } | null = null;

	canvas.addEventListener('touchstart', (e) => {
		e.preventDefault();
		if (gameOver) { resetGame(); return; }
		if (won && !keepPlaying) { keepPlaying = true; draw(1); }
		const t = e.touches[0];
		touchStart = { x: t.clientX, y: t.clientY };
	}, { passive: false });

	canvas.addEventListener('touchmove', (e) => {
		e.preventDefault();
		if (!touchStart) return;
		const t = e.touches[0];
		const dx = t.clientX - touchStart.x;
		const dy = t.clientY - touchStart.y;
		const threshold = 30;

		if (Math.abs(dx) > threshold || Math.abs(dy) > threshold) {
			if (Math.abs(dx) > Math.abs(dy)) {
				move(dx > 0 ? 'right' : 'left');
			} else {
				move(dy > 0 ? 'down' : 'up');
			}
			touchStart = null;
		}
	}, { passive: false });

	canvas.addEventListener('click', () => {
		if (gameOver) resetGame();
		else if (won && !keepPlaying) { keepPlaying = true; draw(1); }
	});

	resetButton?.addEventListener('click', resetGame);

	// Init
	resizeCanvas();
	resetGame();
	window.addEventListener('resize', () => { resizeCanvas(); draw(1); });
</script>
