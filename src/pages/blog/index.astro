---
import { getCollection } from 'astro:content';
import TimelinePost from '../../components/TimelinePost.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Journal | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="intro intro--compact fade-in">
			<p class="eyebrow">Archive</p>
			<h1>All notes.</h1>
		</section>

		<section class="timeline" aria-label="All posts">
			{posts.map((post, index) => <TimelinePost post={post} index={index} />)}
		</section>
	</main>
</BaseLayout>
