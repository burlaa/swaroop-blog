---
import { getCollection } from 'astro:content';
import TimelinePost from '../components/TimelinePost.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="intro fade-in">
			<p class="eyebrow">Engineering journal</p>
			<h1>Notes on building clear, reliable software.</h1>
			<p>
				A quiet place for technical writing about web architecture, systems thinking, developer
				tools, and the practical details that make software feel composed.
			</p>
		</section>

		<section class="timeline" aria-label="Latest posts">
			{posts.map((post, index) => <TimelinePost post={post} index={index} />)}
		</section>
	</main>
</BaseLayout>
