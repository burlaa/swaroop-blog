---
import { getCollection } from 'astro:content';
import TimelinePost from '../components/TimelinePost.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="intro fade-in">
			<p class="eyebrow">Learning journal</p>
			<h1>Curated by Curiosity</h1>
			<p>
				Small notes from books, code, work, and life. Written while the thought is still warm.
			</p>
		</section>

		<section class="timeline" aria-label="Latest posts">
			{posts.map((post, index) => <TimelinePost post={post} index={index} />)}
		</section>
	</main>
</BaseLayout>
